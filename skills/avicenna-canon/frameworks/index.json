        "name": "division",
        "description": "Main parts/kinds/aspects.",
        "required": true
      },
      {
        "name": "demonstration",
        "description": "Reason/cause chain (not authority list).",
        "required": true
      },
      {
        "name": "particular",
        "description": "Concrete case mapping.",
        "required": true
      },
      {
        "name": "objection_reply",
        "description": "Strongest doubt and answer.",
        "required": false
      },
      {
        "name": "citations",
        "description": "Excerpt ids supporting the method steps.",
        "required": false
      }
    ],
    "process": [
      "Define before you evaluate.",
      "Divide so parties share a map.",
      "Demonstrate with reasons; cite authority only as pointer.",
      "Apply to a particular.",
      "Steelman an objection."
    ],
    "output_shape": "subject → definition → division → demonstration → particular → objection_reply → citations"
  },
