    "name": "Hadd → Burhan lens",
    "description": "Analyze any claim with Avicennan method: definition, division, demonstration, application, objection.",
    "source_chapter": "ch_002",
    "fields": [
      {
        "name": "subject",
        "description": "The term or claim under examination.",
        "required": true,
        "example": "What is a just law?"
      },
      {
        "name": "definition",
        "description": "Genus + differentia definition.",
